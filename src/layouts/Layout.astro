---
interface Props {
  titolo: string;
}
const { titolo } = Astro.props;

const voci = [
  { href: '/', label: 'Home' },
  { href: '/il-progetto', label: 'Il progetto' },
  { href: '/lo-spazio', label: 'Lo spazio' },
  { href: '/contatti', label: 'Contatti' },
];
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{titolo} — Progetto Drama APS</title>
  </head>
  <body>
    <header class="sito-header">
      <a class="logo" href="/">Progetto Drama</a>
      <nav>
        <ul>
          {voci.map((voce) => (
            <li><a href={voce.href}>{voce.label}</a></li>
          ))}
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="sito-footer">
      <p>Progetto Drama APS — Via Giovanni Caselli 39, Roma — C.F. 96653370583</p>
    </footer>

    <style>
      :root {
        color-scheme: light;
        font-family: system-ui, sans-serif;
      }
      body {
        margin: 0;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }
      .sito-header {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #ddd;
      }
      .logo {
        font-weight: bold;
        font-size: 1.2rem;
        text-decoration: none;
        color: inherit;
      }
      nav ul {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }
      nav a {
        text-decoration: none;
        color: inherit;
      }
      nav a:hover {
        text-decoration: underline;
      }
      main {
        flex: 1;
        width: 100%;
        max-width: 60rem;
        margin: 0 auto;
        padding: 1.5rem;
        box-sizing: border-box;
      }
      .sito-footer {
        padding: 1.5rem;
        border-top: 1px solid #ddd;
        font-size: 0.85rem;
        text-align: center;
      }
    </style>
  </body>
</html>
