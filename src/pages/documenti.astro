---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';

const documenti = [
  { file: 'statuto.pdf', titolo: 'Statuto' },
  { file: 'atto-costitutivo.pdf', titolo: 'Atto costitutivo' },
  { file: 'informativa-privacy.pdf', titolo: 'Informativa privacy' },
];

const cartellaPubblica = path.join(process.cwd(), 'public', 'documenti');
const elenco = documenti.map((doc) => ({
  ...doc,
  presente: fs.existsSync(path.join(cartellaPubblica, doc.file)),
}));
---

<Layout titolo="Documenti">
  <h1>Documenti</h1>
  <p class="intro">Statuto, atto costitutivo e informativa privacy dell'associazione.</p>

  <ul class="documenti">
    {elenco.map((doc) => (
      <li>
        {doc.presente ? (
          <a href={`/documenti/${doc.file}`} target="_blank" rel="noopener">{doc.titolo} (PDF)</a>
        ) : (
          <span class="mancante">{doc.titolo} — PDF non ancora caricato</span>
        )}
        {doc.file === 'informativa-privacy.pdf' && (
          <> · <a href="/informativa-privacy">leggila sul sito</a></>
        )}
      </li>
    ))}
  </ul>
</Layout>

<style>
  .intro {
    color: var(--color-ink-muted);
    margin: 0 0 24px;
  }
  .documenti {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .documenti li {
    padding: 14px 0;
    border-bottom: 1px solid var(--color-border);
  }
  .documenti a {
    color: var(--color-accent);
    font-weight: 500;
    text-decoration: none;
  }
  .documenti a:hover {
    text-decoration: underline;
  }
  .mancante {
    color: var(--color-ink-muted);
    font-style: italic;
  }
</style>
