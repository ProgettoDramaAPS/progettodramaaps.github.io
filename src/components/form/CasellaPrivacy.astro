---
interface Props {
  id: string;
  name: string;
  value: string;
  required?: boolean;
}
const { id, name, value, required = true } = Astro.props;
---

<div class="campo consenso">
  <input type="checkbox" id={id} name={name} required={required} value={value} />
  <label for={id}><slot /></label>
</div>

<style>
  .consenso {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    margin-bottom: 20px;
  }
  .consenso input[type='checkbox'] {
    margin-top: 3px;
    width: 16px;
    height: 16px;
    accent-color: var(--color-accent);
    flex-shrink: 0;
  }
  .consenso label {
    font-size: 13px;
    font-weight: 400;
    color: var(--color-ink-muted);
    margin: 0;
    line-height: 1.55;
  }
</style>
